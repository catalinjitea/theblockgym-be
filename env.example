# ── Netopia Payments ──────────────────────────────────────────────────────────
# Get these from https://admin.netopia-payments.com
NETOPIA_API_KEY=your-api-key-here
NETOPIA_POS_SIGNATURE=your-pos-signature-here
NETOPIA_IS_LIVE=false
# RSA public key from Netopia — wrap in double quotes to preserve newlines
NETOPIA_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
YOUR_KEY_BODY_HERE
-----END PUBLIC KEY-----"

# ── Resend (email) ────────────────────────────────────────────────────────────
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=noreply@yourdomain.com
# Public URL for the logo used in emails (must be accessible by email clients, not localhost)
EMAIL_LOGO_URL=https://yourdomain.com/logo.png

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
