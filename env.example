# ── Netopia Payments ──────────────────────────────────────────────────────────
# Get these from https://admin.netopia-payments.com
NETOPIA_API_KEY=your-api-key-here
NETOPIA_POS_SIGNATURE=your-pos-signature-here
NETOPIA_IS_LIVE=false
# RSA public key from Netopia — wrap in double quotes to preserve newlines
NETOPIA_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
YOUR_KEY_BODY_HERE
-----END PUBLIC KEY-----"

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
